{
  "kind": "collectionType",
  "collectionName": "movies",
  "info": {
    "singularName": "movie",
    "pluralName": "movies",
    "displayName": "Movie"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string"
    },
    "watched": {
      "type": "boolean"
    },
    "rating": {
      "type": "decimal"
    },
    "user": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user",
      "inversedBy": "movies"
    },
    "tmdbId": {
      "type": "biginteger"
    },
    "posterUrl": {
      "type": "text"
    }
  }
}
